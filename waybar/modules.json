{
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{name}",
    "persistent-workspaces": {
      "*": [1, 2, 3, 4, 5, 6, 7, 8, 9]
    }
  },
  "hyprland/window": {
    "max-length": 36,
    "separate-outputs": true,
    "rewrite": {
      "(.*)Mozilla Firefox(.*)": "َ°ˆ¹ Firefox",
      "(.*)Brave(.*)": "َ°–ں Brave",
      "(.*)Alacritty(.*)": " Alacritty",
      "(.*)nvim(.*)": " Neovim",
      "(.*)VSCode(.*)": "َ°¨‍ VSCode",
      "(.*)Code(.*)": "َ°¨‍ VSCode",
      "(.*)Spotify(.*)": "َ°“‡ Spotify",
      "(.*)Discord(.*)": "َ°™¯ Discord",
      "(.*)Thunar(.*)": "َ°‰‹ Files",
      "(.*)Steam(.*)": "َ°““ Steam",
      "(.*)superfile(.*)": "َ°‰‹ Superfile",
      "": ""
    }
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں muted",
