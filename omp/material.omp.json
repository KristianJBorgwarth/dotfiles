{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "<#4589ff>❯</><#78a9ff>❯</>",
          "foreground": "#f2f4f8",
          "type": "text",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "style": "agnoster_short"
          },
          "template": " {{ .Path }} ",
          "foreground": "#c1c7cd",
          "type": "path",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "<#78a9ff>❯</>",
          "foreground": "#f2f4f8",
          "type": "text",
          "style": "plain"
        },
        {
          "properties": {
            "branch_icon": "",
            "cache_duration": "none",
            "fetch_status": false,
            "fetch_upstream_icon": true
          },
          "template": "<#33b1ff>(</>{{ .HEAD }}<#33b1ff>)</>",
          "foreground": "#878d96",
          "type": "git",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "<#78a9ff>❯</>",
          "foreground": "#f2f4f8",
          "type": "text",
          "style": "plain"
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "properties": {
            "cache_duration": "none",
            "time_format": "15:04"
          },
          "template": " {{ .CurrentDate | date .Format }} ",
          "foreground": "#878d96",
          "type": "time",
          "style": "plain"
        }
      ]
    }
  ],
  "version": 3
}
