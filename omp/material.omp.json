{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "<#81a1c1>❯</><#a3be8c>❯</>",
          "foreground": "#d8dee9",
          "type": "text",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "style": "agnoster_short"
          },
          "template": " {{ .Path }} ",
          "foreground": "#88c0d0",
          "type": "path",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "<#a3be8c>❯</>",
          "foreground": "#d8dee9",
          "type": "text",
          "style": "plain"
        },
        {
          "properties": {
            "branch_icon": "",
            "cache_duration": "none",
            "fetch_status": false,
            "fetch_upstream_icon": true
          },
          "template": "<#5e81ac>(</>{{ .HEAD }}<#5e81ac>)</>",
          "foreground": "#8fbcbb",
          "type": "git",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "<#a3be8c>❯</>",
          "foreground": "#d8dee9",
          "type": "text",
          "style": "plain"
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "properties": {
            "cache_duration": "none",
            "time_format": "15:04"
          },
          "template": " {{ .CurrentDate | date .Format }} ",
          "foreground": "#a3be8c",
          "type": "time",
          "style": "plain"
        }
      ]
    }
  ],
  "version": 3
}
