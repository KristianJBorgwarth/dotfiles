{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "<#527a63>❯</><#6b9a96>❯</>",
          "foreground": "#c4ccda",
          "type": "text",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "style": "agnoster_short"
          },
          "template": " {{ .Path }} ",
          "foreground": "#7090a8",
          "type": "path",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "<#6b9a96>❯</>",
          "foreground": "#c4ccda",
          "type": "text",
          "style": "plain"
        },
        {
          "properties": {
            "branch_icon": "",
            "cache_duration": "none",
            "fetch_status": false,
            "fetch_upstream_icon": true
          },
          "template": "<#7090a8>(</>{{ .HEAD }}<#7090a8>)</>",
          "foreground": "#6b9a96",
          "type": "git",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "<#6b9a96>❯</>",
          "foreground": "#c4ccda",
          "type": "text",
          "style": "plain"
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "properties": {
            "cache_duration": "none",
            "time_format": "15:04"
          },
          "template": " {{ .CurrentDate | date .Format }} ",
          "foreground": "#6b9a96",
          "type": "time",
          "style": "plain"
        }
      ]
    }
  ],
  "version": 3
}
